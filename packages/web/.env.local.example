# Terminal server ports (14800 range chosen to avoid conflicts with dev tools)
TERMINAL_PORT=14800                 # ttyd (iframe) terminal server
DIRECT_TERMINAL_PORT=14801          # Direct WebSocket terminal server with XDA support

# Public environment variables (exposed to browser)
NEXT_PUBLIC_TERMINAL_PORT=14800
NEXT_PUBLIC_DIRECT_TERMINAL_PORT=14801

# GitHub PAT — used by the gh CLI for the tracker-github plugin
# GH_TOKEN=ghp_...

# ---------------------------------------------------------------------------
# Tracker secrets (global defaults — apply to all projects unless overridden)
# ---------------------------------------------------------------------------
# Jira — https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_BASE_URL=https://myorg.atlassian.net
# JIRA_EMAIL=me@example.com
# JIRA_API_TOKEN=ATATT3x...

# Linear
# LINEAR_API_KEY=lin_api_...

# Azure DevOps
# AZURE_DEVOPS_ORG_URL=https://dev.azure.com/myorg
# AZURE_DEVOPS_PAT=...

# ---------------------------------------------------------------------------
# Per-project overrides
# ---------------------------------------------------------------------------
# If a project in agent-orchestrator.yaml sets `envFile: .env.agentboard`,
# the variables in that file override the globals above for that project only.
# This lets you use a different Jira org / PAT per project:
#
#   projects:
#     work-app:
#       envFile: .env.agentboard   # ~/work-app/.env.agentboard
#       tracker:
#         plugin: jira
#         projectKey: WORK
#
# Inside ~/work-app/.env.agentboard:
#   JIRA_BASE_URL=https://other-org.atlassian.net
#   JIRA_EMAIL=me@other-org.com
#   JIRA_API_TOKEN=ATATT3x_other...
